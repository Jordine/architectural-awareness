# Large model files
*.pt
*.bin
*.safetensors
*.gguf
*.onnx

# Modified model directories (large)
modified_*/

# Track results JSONs but not model weights in results
!results/**/*.json
results/**/*.bin
results/**/*.safetensors
results/**/model*
results/**/tokenizer*
results/**/config.json
results/**/generation_config.json
results/**/special_tokens_map.json

# LoRA adapter weights (small, track them)
!results/**/adapter_config.json
results/**/adapter_model*

# Python
__pycache__/
*.pyc

# Theory/notes (local only)
*.txt

# Environment
.env
*.log
nohup.out

# Large files
*.gguf
*.onnx
